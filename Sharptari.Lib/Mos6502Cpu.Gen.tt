<# GenAbsoluteYIndexed("LDX"); #>

<# GenImmediate("LDY"); #>
<# GenZeropage("LDY"); #>
<# GenZeropageXIndexed("LDY"); #>
<# GenAbsolute("LDY"); #>
<# GenAbsoluteXIndexed("LDY"); #>

<# GenImpl("NOP"); #>
<# GenImmediate("NOP"); #>
<# GenZeropage("NOP"); #>
<# GenZeropageXIndexed("NOP"); #>
<# GenAbsolute("NOP"); #>
<# GenAbsoluteXIndexed("NOP"); #>
}
<#+


private void GenImpl(string op)
{
#>
    private void <#= op #>_impl()
    {
        _ = m_Bus.Read(m_Registers.PC);
        m_CurrentOpCodeCycle = 0;
        <#= op #>();
    }
<#+
}

private void GenImmediate(string op)
{
#>
    private void <#= op #>_immediate()
    {
        m_SavedValue0 = m_Bus.Read(m_Registers.PC);
        ++m_Registers.PC;
        m_CurrentOpCodeCycle = 0;
        <#= op #>();
    }
<#+
}

private void GenZeropage(string op)
{
#>
    private void <#= op #>_zeropage()
    {
        switch (m_CurrentOpCodeCycle)
        {
            case 1:
                m_SavedValue0 = m_Bus.Read(m_Registers.PC);
                ++m_Registers.PC;
                m_CurrentOpCodeCycle = 2;
                break;
            default:
                m_SavedValue0 = m_Bus.Read(m_SavedValue0);
                m_CurrentOpCodeCycle = 0;
                <#= op #>();
                break;
        }
    }
<#+
}

private void GenZeropageXIndexed(string op)
{
#>
    private void <#= op #>_zeropage_xindexed()
    {
        switch (m_CurrentOpCodeCycle)
        {
            case 1:
                m_SavedValue0 = m_Bus.Read(m_Registers.PC);
                ++m_Registers.PC;
                m_CurrentOpCodeCycle = 2;
                break;
            case 2:
                _ = m_Bus.Read(m_SavedValue0);
                m_CurrentOpCodeCycle = 3;
                break;
            default:
                m_SavedValue0 = m_Bus.Read(GetZeropageIndexedNoCarry(m_SavedValue0, m_Registers.X));
                m_CurrentOpCodeCycle = 0;
                <#= op #>();
                break;
        }
    }
<#+
}

private void GenZeropageYIndexed(string op)
{
#>
    private void <#= op #>_zeropage_yindexed()
    {
        switch (m_CurrentOpCodeCycle)
        {
            case 1:
                m_SavedValue0 = m_Bus.Read(m_Registers.PC);
                ++m_Registers.PC;
                m_CurrentOpCodeCycle = 2;
                break;
            case 2:
                _ = m_Bus.Read(m_SavedValue0);
                m_CurrentOpCodeCycle = 3;
                break;
            default:
                m_SavedValue0 = m_Bus.Read(GetZeropageIndexedNoCarry(m_SavedValue0, m_Registers.Y));
                m_CurrentOpCodeCycle = 0;
                <#= op #>();
                break;
        }
    }
<#+
}

private void GenAbsolute(string op)
{
#>
    private void <#= op #>_absolute()
    {
        switch (m_CurrentOpCodeCycle)
        {
            case 1:
                m_SavedValue0 = m_Bus.Read(m_Registers.PC);
                ++m_Registers.PC;
                m_CurrentOpCodeCycle = 2;
                break;
            case 2:
                m_SavedValue1 = m_Bus.Read(m_Registers.PC);
                ++m_Registers.PC;
                m_CurrentOpCodeCycle = 3;
                break;
            default:
                m_SavedValue0 = m_Bus.Read(GetAbsolute(m_SavedValue0, m_SavedValue1));
                m_CurrentOpCodeCycle = 0;
                <#= op #>();
                break;
        }
    }
<#+
}

private void GenAbsoluteXIndexed(string op)
{
#>
    private void <#= op #>_absolute_xindexed()
    {
        switch (m_CurrentOpCodeCycle)
        {
            case 1:
                m_SavedValue0 = m_Bus.Read(m_Registers.PC);
                ++m_Registers.PC;
                m_CurrentOpCodeCycle = 2;
                break;
            case 2:
                m_SavedValue1 = m_Bus.Read(m_Registers.PC);
                ++m_Registers.PC;
                m_CurrentOpCodeCycle = 3;
                break;
            case 3:
                if (m_SavedValue0 + m_Registers.X > 0xFF)
                {
                    _ = m_Bus.Read(GetAbsoluteIndexedNoCarry(m_SavedValue0, m_SavedValue1, m_Registers.X));
                    m_CurrentOpCodeCycle = 4;
                }
                else
                {
                    m_SavedValue0 = m_Bus.Read(GetAbsoluteIndexedNoCarry(m_SavedValue0, m_SavedValue1, m_Registers.X));
                    m_CurrentOpCodeCycle = 0;
                    <#= op #>();
                }
                break;
            default:
                m_SavedValue0 = m_Bus.Read(GetAbsoluteIndexed(m_SavedValue0, m_SavedValue1, m_Registers.X));
                m_CurrentOpCodeCycle = 0;
                <#= op #>();
                break;
        }
    }
<#+
}

private void GenAbsoluteYIndexed(string op)
{
#>
    private void <#= op #>_absolute_yindexed()
    {
        switch (m_CurrentOpCodeCycle)
        {
            case 1:
                m_SavedValue0 = m_Bus.Read(m_Registers.PC);
