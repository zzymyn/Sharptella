private void ReadImmediate(string op)
{
#>
    private void <#= op #>_immediate()
    {
        m_SavedValue2 = m_Bus.Read(m_Registers.PC);
        ++m_Registers.PC;
        m_CurrentOpCodeCycle = 0;
        <#= op #>(m_SavedValue2);
    }
<#+
}

private void ReadZeropage(string op)
{
#>
    private void <#= op #>_zeropage()
    {
        switch (m_CurrentOpCodeCycle)
        {
            case 1:
                m_SavedValue0 = m_Bus.Read(m_Registers.PC);
                ++m_Registers.PC;
                m_CurrentOpCodeCycle = 2;
                break;
            default:
                m_SavedValue2 = m_Bus.Read(m_SavedValue0);
                m_CurrentOpCodeCycle = 0;
                <#= op #>(m_SavedValue2);
                break;
        }
    }
<#+
}

