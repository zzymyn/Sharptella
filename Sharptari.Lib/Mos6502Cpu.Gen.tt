                    m_CurrentOpCodeCycle = 4;
                }
                else
                {
                    m_SavedValue2 = m_Bus.Read(GetAbsoluteIndexedNoCarry(m_SavedValue0, m_SavedValue1, m_Registers.X));
                    m_CurrentOpCodeCycle = 0;
                    <#= op #>(m_SavedValue2);
