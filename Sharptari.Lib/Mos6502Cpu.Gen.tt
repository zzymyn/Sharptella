using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Sharptari.Lib;

public sealed partial class Mos6502Cpu
{
<# GenImmediate("ADC"); #>
<# GenZeropage("ADC"); #>
<# GenZeropageXIndexed("ADC"); #>
<# GenAbsolute("ADC"); #>
<# GenAbsoluteXIndexed("ADC"); #>
<# GenAbsoluteYIndexed("ADC"); #>
<# GenIndirectXIndexed("ADC"); #>
<# GenIndirectYIndexed("ADC"); #>

<# GenImmediate("AND"); #>
<# GenZeropage("AND"); #>
<# GenZeropageXIndexed("AND"); #>
<# GenAbsolute("AND"); #>
<# GenAbsoluteXIndexed("AND"); #>
<# GenAbsoluteYIndexed("AND"); #>
<# GenIndirectXIndexed("AND"); #>
<# GenIndirectYIndexed("AND"); #>

<# GenImmediate("LDA"); #>
<# GenZeropage("LDA"); #>
<# GenZeropageXIndexed("LDA"); #>
<# GenAbsolute("LDA"); #>
<# GenAbsoluteXIndexed("LDA"); #>
<# GenAbsoluteYIndexed("LDA"); #>
<# GenIndirectXIndexed("LDA"); #>
<# GenIndirectYIndexed("LDA"); #>

<# GenImmediate("LDX"); #>
